<%- include('../partials/header', { title: 'My Fees' }) %>

    <head>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    </head>

    <div class="container mt-5">
        <h2 class="fw-bold mb-4">My Fee Status</h2>

        <div class="card shadow p-4">
            <table class="table">
                <thead>
                    <tr>
                        <th>Month</th>
                        <th>Year</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    <% if (fees.length===0) { %>
                        <tr>
                            <td colspan="4" class="text-center text-muted">
                                No fee records found.
                            </td>
                        </tr>
                        <% } %>

                            <% fees.forEach(f=> { %>
                                <tr>
                                    <td>
                                        <%= f.month %>
                                    </td>
                                    <td>
                                        <%= f.year %>
                                    </td>

                                    <td>
                                        <% if (f.is_paid) { %>
                                            <span class="badge bg-success">Paid</span>
                                            <% } else { %>
                                                <span class="badge bg-danger">Unpaid</span>
                                                <% } %>
                                    </td>

                                    <td>
                                        <% if (!f.is_paid) { %>
                                            <form action="/student/fees/mark-paid" method="POST">
                                                <input type="hidden" name="month" value="<%= f.month %>">
                                                <input type="hidden" name="year" value="<%= f.year %>">

                                                <button class="btn btn-sm btn-primary">
                                                    Mark as Paid
                                                </button>
                                            </form>
                                            <% } else { %>
                                                <span class="text-muted">✔ Completed</span>
                                                <% } %>
                                    </td>
                                </tr>
                                <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <%- include('../partials/footer') %>