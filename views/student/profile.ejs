<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile | TuitionPro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
        rel="stylesheet">

    <style>
        :root {
            --primary: #4361ee;
            --main-bg: #f4f7fe;
            --text-dark: #2b3674;
            --card-shadow: 0 10px 30px rgba(163, 174, 208, 0.15);
            --border-color: #e2e8f0;
        }

        body {
            background-color: var(--main-bg);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-dark);
            margin: 0;
            display: flex;
        }

        /* --- SIDEBAR --- */
        .sidebar {
            width: 260px;
            height: 100vh;
            background: #fff;
            position: fixed;
            left: 0;
            top: 0;
            padding: 24px;
            display: flex;
            flex-direction: column;
            box-shadow: 4px 0 24px rgba(0, 0, 0, 0.02);
            z-index: 100;
        }

        .brand {
            font-weight: 700;
            font-size: 1.5rem;
            color: var(--primary);
            text-decoration: none;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: #a3aed0;
            text-decoration: none;
            font-weight: 600;
            border-radius: 12px;
            transition: 0.3s;
            margin-bottom: 8px;
        }

        .nav-link:hover,
        .nav-link.active {
            background: #f4f7fe;
            color: var(--primary);
        }

        .logout-link {
            margin-top: auto;
            color: #ee5d50 !important;
        }

        /* --- MAIN CONTENT & TOP NAV --- */
        .main-content {
            margin-left: 260px;
            width: calc(100% - 260px);
            min-height: 100vh;
        }

        .top-nav {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            background: #ffffff;
            padding: 15px 30px;
            width: 100%;
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 90;
            margin-bottom: 30px;
        }

        .profile-pill {
            background: #f4f7fe;
            padding: 6px 18px;
            border-radius: 50px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            transition: 0.3s;
            border: 1px solid transparent;
        }

        .profile-pill:hover {
            border-color: var(--primary);
        }

        .avatar {
            width: 32px;
            height: 32px;
            background: var(--primary);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
        }

        .dashboard-body {
            padding: 0 30px 30px 30px;
        }

        /* --- PROFILE COMPONENTS --- */
        .profile-header-card {
            background: linear-gradient(135deg, var(--primary) 0%, #7209b7 100%);
            border-radius: 24px;
            padding: 40px;
            color: white;
            text-align: center;
        }

        .large-avatar {
            width: 100px;
            height: 100px;
            background: white;
            color: var(--primary);
            font-size: 2.5rem;
            font-weight: 700;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            border: 4px solid rgba(255, 255, 255, 0.3);
        }

        .info-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: var(--card-shadow);
            border: none;
            height: 100%;
        }

        .label-text {
            font-size: 0.75rem;
            color: #a3aed0;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .value-text {
            font-size: 1rem;
            color: var(--text-dark);
            font-weight: 600;
            margin-bottom: 20px;
        }

        .stat-badge {
            background: rgba(255, 255, 255, 0.1);
            padding: 12px;
            border-radius: 16px;
            text-align: center;
            flex: 1;
            backdrop-filter: blur(5px);
        }
    </style>
</head>

<body>

    <div class="sidebar">
        <a href="#" class="brand">
            <i class="fa-solid fa-graduation-cap"></i> <span>TuitionPro</span>
        </a>
        <nav>
            <a href="/student/dashboard" class="nav-link">
                <i class="fa-solid fa-house"></i> <span>Dashboard</span>
            </a>
            <a href="/student/doubts" class="nav-link">
                <i class="fa-solid fa-comment-dots"></i> <span>Post Doubts</span>
            </a>
            <a href="/student/tasks" class="nav-link">
                <i class="fa-solid fa-file-pen"></i> <span>Assignments</span>
            </a>
            <a href="/student/fees" class="nav-link">
                <i class="fa-solid fa-wallet"></i> <span>Due Fees</span>
            </a>
        </nav>
        <a href="/logout" class="nav-link logout-link">
            <i class="fa-solid fa-power-off"></i> <span>Logout</span>
        </a>
    </div>

    <div class="main-content">
        <header class="top-nav">
            <a href="/student/profile" class="text-decoration-none">
                <div class="profile-pill">
                    <span class="d-none d-sm-inline text-dark">Student Portal</span>
                    <div class="avatar">SU</div>
                </div>
            </a>
        </header>

        <div class="dashboard-body">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="profile-header-card shadow">
                        <div class="large-avatar">SU</div>
                        <h4 class="fw-bold mb-1">
                            <%= student.full_name %>
                        </h4>
                        <p class="opacity-75 mb-4 small">Student ID: #<%= student.id %>
                        </p>

                        <div class="d-flex gap-2">
                            <div class="stat-badge">
                                <div class="fw-bold h5 mb-0">
                                    <%= stats.completed %>
                                </div>
                                <div class="small opacity-75">Tasks</div>
                            </div>
                            <div class="stat-badge">
                                <div class="fw-bold h5 mb-0">Active</div>
                                <div class="small opacity-75">Status</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="info-card">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="fw-bold mb-0">Personal Information</h5>
                            <button class="btn btn-primary btn-sm rounded-pill px-3">Edit Profile</button>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="label-text">Full Name</div>
                                <div class="value-text">
                                    <%= student.full_name %>
                                </div>

                                <div class="label-text">Email Address</div>
                                <div class="value-text">
                                    <%= user.email %>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="label-text">Class / Grade</div>
                                <div class="value-text">
                                    <%= student.class || 'N/A' %>
                                </div>

                                <div class="label-text">Monthly Fees</div>
                                <div class="value-text">$<%= student.monthly_fees %>
                                </div>
                            </div>
                            <div class="col-12 mt-2">
                                <div class="label-text">School / Institution</div>
                                <div class="value-text">
                                    <%= student.school || 'Not specified' %>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" style="opacity: 0.1;">

                        <h6 class="fw-bold mb-3 text-primary">Academic Progress</h6>
                        <div class="progress mb-2" style="height: 8px; border-radius: 10px;">
                            <div class="progress-bar bg-primary" role="progressbar" style="width: 75%;"
                                aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <p class="text-muted small mb-0">You have completed 75% of your assigned tasks this month.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>

</html>