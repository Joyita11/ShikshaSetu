<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Assignments | ShikshaSetu</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans..." rel="stylesheet">

    <style>
        :root {
            --primary: #060e34;
            --sidebar-bg: #2d296525;
            --main-bg: #c5afee26;
            --text-dark: #2b3674;
            --card-shadow: 0 10px 30px rgba(163, 174, 208, 0.1);
            --border-color: #e2e8f0;
        }

        body {
            background: #f4f7fe;
            font-family: sans-serif;
            margin: 0;
            display: flex;
        }

        /* SIDEBAR */

        .sidebar {
            width: 260px;
            height: 100vh;
            background: var(--sidebar-bg);
            position: fixed;
            left: 0;
            top: 0;
            padding: 24px;
            display: flex;
            flex-direction: column;
            box-shadow: 4px 0 24px rgba(0, 0, 0, 0.02);
            z-index: 100;
        }

        .brand {
            font-weight: 700;
            font-size: 1.5rem;
            color: var(--primary);
            text-decoration: none;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: #4d5c88;
            text-decoration: none;
            font-weight: 600;
            border-radius: 12px;
            transition: 0.3s;
            margin-bottom: 8px;
        }

        .nav-link:hover,
        .nav-link.active {
            background: #c5afee5b;
            color: var(--primary);
        }

        .logout-link {
            margin-top: auto;
            color: #ee5d50 !important;
        }


        /* MAIN */

        .main-content {
            margin-left: 260px;
            width: calc(100% - 260px);
            padding: 30px;
        }

        /* ASSIGNMENT CARD */

        .assignment-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(163, 174, 208, 0.15);
            margin-bottom: 24px;
            padding: 24px;
        }

        .assignment-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
        }

        .status-pill {
            padding: 6px 16px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .status-pending {
            background: #fff4e5;
            color: #ff9800;
        }

        .status-completed {
            background: #e6f9f0;
            color: #00b894;
        }

        .task-list-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 0;
            border-bottom: 1px solid #eee;
        }

        .task-button {
            border: none;
            background: none;
            cursor: pointer;
            font-size: 18px;
        }

        .download-btn {
            background: #f4f7fe;
            color: #4361ee;
            font-weight: 600;
            border-radius: 10px;
            padding: 8px 16px;
            text-decoration: none;
        }
    </style>
</head>


<body>

    <!-- SIDEBAR -->

    <div class="sidebar">
        <a href="#" class="brand">
            <i class="fa-solid fa-graduation-cap"></i>
            <span>ShikshaSetu</span>
        </a>

        <nav>
            <a href="/student/dashboard" class="nav-link">
                <i class="fa-solid fa-house"></i> <span>Dashboard</span>
            </a>
            <a href="/student/doubts" class="nav-link">
                <i class="fa-solid fa-comment-dots"></i> <span>Post Doubts</span>
            </a>
            <a href="/student/tasks" class="nav-link active">
                <i class="fa-solid fa-file-pen"></i> <span>Assignments</span>
            </a>
            <a href="/student/fees" class="nav-link">
                <i class="fa-solid fa-wallet"></i> <span>Due Fees</span>
            </a>
        </nav>

        <a href="/logout" class="nav-link logout-link">
            <i class="fa-solid fa-power-off"></i> <span>Logout</span>
        </a>
    </div>


    <!-- MAIN CONTENT -->

    <div class="main-content">

        <h2 class="mb-4">My Assignments 📚</h2>

        <div class="row">

            <% if(assignments && assignments.length> 0){ %>

                <% assignments.forEach(function(a){ %>

                    <div class="col-12">

                        <div class="assignment-card">

                            <div class="assignment-header">

                                <div>

                                    <span
                                        class="status-pill <%= a.status === 'Completed' ? 'status-completed' : 'status-pending' %>">

                                        <%= a.status || "Pending" %>

                                    </span>

                                    <h4 class="mt-2">
                                        <%= a.title %>
                                    </h4>

                                    <small class="text-muted">

                                        Assigned on <%= new Date(a.created_at).toLocaleDateString() %>

                                    </small>

                                </div>


                                <% if(a.material_path){ %>

                                    <a href="<%= a.material_path %>" class="download-btn" target="_blank">
                                        <i class="fa-solid fa-cloud-arrow-down"></i> Study Material
                                    </a>

                                    <% } %>

                            </div>


                            <h6 class="mt-3">Tasks</h6>


                            <% if(a.tasks && a.tasks.length> 0){ %>

                                <% a.tasks.forEach(function(task){ %>

                                    <form action="/student/tasks/complete/<%= task.id %>" method="POST">

                                        <div class="task-list-item">

                                            <button type="submit" class="task-button">

                                                <% if(task.is_completed){ %>

                                                    <i class="fa-solid fa-circle-check text-success"></i>

                                                    <% } else { %>

                                                        <i class="fa-regular fa-circle"></i>

                                                        <% } %>

                                            </button>

                                            <span
                                                style="<%= task.is_completed ? 'text-decoration:line-through;color:gray;' : '' %>">

                                                <%= task.task_text %>

                                            </span>

                                        </div>

                                    </form>

                                    <% }) %>

                                        <% } else { %>

                                            <p class="text-muted">No tasks added</p>

                                            <% } %>

                        </div>

                    </div>

                    <% }) %>


                        <% } else { %>

                            <div class="text-center mt-5">

                                <h5 class="text-muted">

                                    No assignments found. You're all caught up!

                                </h5>

                            </div>

                            <% } %>

        </div>

    </div>

</body>

</html>