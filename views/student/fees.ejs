<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Fees | ShikshaSetu</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
        rel="stylesheet">

    <style>
        :root {
            --primary: #060e34;
            --sidebar-bg: #2d296525;
            --main-bg: #c5afee26;
            --text-dark: #2b3674;
            --card-shadow: 0 10px 30px rgba(163, 174, 208, 0.1);
            --border-color: #e2e8f0;
        }

        body {
            background-color: var(--main-bg);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-dark);
            margin: 0;
            display: flex;
        }

        /* --- SIDEBAR (Shared with Dashboard) --- */
        .sidebar {
            width: 260px;
            height: 100vh;
            background: var(--sidebar-bg);
            position: fixed;
            left: 0;
            top: 0;
            padding: 24px;
            display: flex;
            flex-direction: column;
            box-shadow: 4px 0 24px rgba(0, 0, 0, 0.02);
            z-index: 100;
        }

        .brand {
            font-weight: 700;
            font-size: 1.5rem;
            color: var(--primary);
            text-decoration: none;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: #4d5c88;
            text-decoration: none;
            font-weight: 600;
            border-radius: 12px;
            transition: 0.3s;
            margin-bottom: 8px;
        }

        .nav-link:hover,
        .nav-link.active {
            background: #c5afee5b;
            color: var(--primary);
        }

        .logout-link {
            margin-top: auto;
            color: #ee5d50 !important;
        }

        /* --- MAIN CONTENT LAYOUT --- */
        .main-content {
            margin-left: 260px;
            width: calc(100% - 260px);
            min-height: 100vh;
        }

        .top-nav {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            background: #ffffff;
            padding: 15px 30px;
            width: 100%;
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 90;
        }

        .profile-pill {
            background: #f4f7fe;
            padding: 6px 18px;
            border-radius: 50px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
        }

        .avatar {
            width: 32px;
            height: 32px;
            background: var(--primary);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
        }

        .dashboard-body {
            padding: 30px;
        }

        /* --- TABLE STYLING --- */
        .fee-card {
            background: white;
            border-radius: 20px;
            padding: 24px;
            box-shadow: var(--card-shadow);
            border: none;
        }

        .table {
            vertical-align: middle;
        }

        .table thead th {
            background-color: #f8faff;
            color: #a3aed0;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 1px;
            border: none;
            padding: 15px;
        }

        .table tbody td {
            padding: 20px 15px;
            border-bottom: 1px solid #f1f4f9;
            font-weight: 600;
        }

        .badge-paid {
            background: #e6f9f0;
            color: #00b894;
            padding: 6px 12px;
            border-radius: 8px;
        }

        .badge-unpaid {
            background: #feecef;
            color: #ee5d50;
            padding: 6px 12px;
            border-radius: 8px;
        }

        .btn-pay {
            background-color: var(--primary);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 13px;
            transition: 0.3s;
        }

        .btn-pay:hover {
            background-color: #3651d1;
            transform: scale(1.05);
        }
    </style>
</head>

<body>

    <div class="sidebar">
        <a href="#" class="brand">
            <i class="fa-solid fa-graduation-cap"></i>
            <span>ShikshaSetu</span>
        </a>

        <nav>
            <a href="/student/dashboard" class="nav-link">
                <i class="fa-solid fa-house"></i> <span>Dashboard</span>
            </a>
            <a href="/student/doubts" class="nav-link">
                <i class="fa-solid fa-comment-dots"></i> <span>Post Doubts</span>
            </a>
            <a href="/student/tasks" class="nav-link">
                <i class="fa-solid fa-file-pen"></i> <span>Assignments</span>
            </a>
            <a href="/student/fees" class="nav-link active">
                <i class="fa-solid fa-wallet"></i> <span>Due Fees</span>
            </a>
        </nav>

        <a href="/logout" class="nav-link logout-link">
            <i class="fa-solid fa-power-off"></i> <span>Logout</span>
        </a>
    </div>

    <div class="main-content">



        <main class="dashboard-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold mb-1">My Fee Status 💳</h2>
                    <p class="text-muted">Track your monthly tuition payments here.</p>
                </div>
            </div>

            <div class="fee-card">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Month</th>
                                <th>Year</th>
                                <th>Status</th>
                                <th>Action</th>
                                <th>Amount</th>
                            </tr>
                        </thead>
                        <tbody>

                            <% if (payments.length===0) { %>
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-5">
                                        <i class="fa-solid fa-folder-open d-block mb-3 fs-2 opacity-25"></i>
                                        No fee records found.
                                    </td>
                                </tr>
                                <% } %>

                                    <% payments.forEach(f=> { %>

                                        <tr>

                                            <td>
                                                <%= f.month %>
                                            </td>

                                            <td>
                                                <%= f.year %>
                                            </td>

                                            <td>
                                                <% if (f.is_paid) { %>
                                                    <span class="badge-paid">
                                                        <i class="fa-solid fa-circle-check me-1"></i> Paid
                                                    </span>
                                                    <% } else { %>
                                                        <span class="badge-unpaid">
                                                            <i class="fa-solid fa-circle-xmark me-1"></i> Unpaid
                                                        </span>
                                                        <% } %>
                                            </td>

                                            <td>

                                                <% if (!f.is_paid) { %>

                                                    <form action="/student/fees/mark-paid" method="POST" class="m-0">
                                                        <input type="hidden" name="month" value="<%= f.month %>">
                                                        <input type="hidden" name="year" value="<%= f.year %>">

                                                        <button class="btn-pay">
                                                            Mark as Paid
                                                        </button>
                                                    </form>

                                                    <% } else { %>

                                                        <span class="text-muted small">
                                                            <i class="fa-solid fa-check-double text-success me-1"></i>
                                                            Completed
                                                        </span>

                                                        <% } %>

                                            </td>
                                            <td>₹ <%= student.monthly_fees %>
                                            </td>
                                        </tr>

                                        <% }) %>

                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

</body>

</html>