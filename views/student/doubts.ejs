<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Post Doubts | ShikshaSetu</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
        rel="stylesheet">

    <style>
        :root {
            --primary: #060e34;
            --sidebar-bg: #2d296525;
            --main-bg: #c5afee26;
            --text-dark: #2b3674;
            --card-shadow: 0 10px 30px rgba(163, 174, 208, 0.1);
            --border-color: #e2e8f0;
        }

        body {
            background-color: var(--main-bg);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-dark);
            margin: 0;
            display: flex;
        }

        /* SIDEBAR */

        .sidebar {
            width: 260px;
            height: 100vh;
            background: var(--sidebar-bg);
            position: fixed;
            left: 0;
            top: 0;
            padding: 24px;
            display: flex;
            flex-direction: column;
            box-shadow: 4px 0 24px rgba(0, 0, 0, 0.02);
            z-index: 100;
        }

        .brand {
            font-weight: 700;
            font-size: 1.5rem;
            color: var(--primary);
            text-decoration: none;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: #4d5c88;
            text-decoration: none;
            font-weight: 600;
            border-radius: 12px;
            transition: 0.3s;
            margin-bottom: 8px;
        }

        .nav-link:hover,
        .nav-link.active {
            background: #c5afee5b;
            color: var(--primary);
        }

        .logout-link {
            margin-top: auto;
            color: #ee5d50 !important;
        }

        /* MAIN */

        .main-content {
            margin-left: 260px;
            width: calc(100% - 260px);
            min-height: 100vh;
        }

        .top-nav {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            background: #ffffff;
            padding: 15px 30px;
            border-bottom: 1px solid var(--border-color);
        }

        .profile-pill {
            background: #f4f7fe;
            padding: 6px 18px;
            border-radius: 50px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
        }

        .avatar {
            width: 32px;
            height: 32px;
            background: var(--primary);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
        }

        .dashboard-body {
            padding: 30px;
        }

        /* FORM */

        .form-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: var(--card-shadow);
            border: none;
        }

        .form-label {
            font-weight: 700;
            font-size: 14px;
        }

        .form-control,
        .form-select {
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            padding: 12px 15px;
            background: #fcfdfe;
        }

        .form-control:focus {
            box-shadow: 0 0 0 4px rgba(67, 97, 238, 0.1);
            border-color: var(--primary);
        }

        .btn-submit {
            background: var(--primary);
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 12px;
            font-weight: 700;
            width: 100%;
        }

        .history-item {
            border-left: 4px solid #e2e8f0;
            padding: 15px;
            background: #f8faff;
            border-radius: 0 12px 12px 0;
            margin-bottom: 15px;
        }

        .status-resolved {
            border-left-color: #00b894;
        }

        .status-pending {
            border-left-color: #ffbb00;
        }
    </style>
</head>


<body>


    <div class="sidebar">

        <a href="#" class="brand">
            <i class="fa-solid fa-graduation-cap"></i>
            <span>ShikshaSetu</span>
        </a>

        <nav>

            <a href="/student/dashboard" class="nav-link">
                <i class="fa-solid fa-house"></i> Dashboard
            </a>

            <a href="/student/doubts" class="nav-link active">
                <i class="fa-solid fa-comment-dots"></i> Post Doubts
            </a>

            <a href="/student/tasks" class="nav-link">
                <i class="fa-solid fa-file-pen"></i> Assignments
            </a>

            <a href="/student/fees" class="nav-link">
                <i class="fa-solid fa-wallet"></i> Due Fees
            </a>

        </nav>

        <a href="/logout" class="nav-link logout-link">
            <i class="fa-solid fa-power-off"></i> Logout
        </a>

    </div>


    <div class="main-content">




        <main class="dashboard-body">

            <div class="mb-4">
                <h2 class="fw-bold mb-1">Ask a Doubt 💡</h2>
                <p class="text-muted">Don't let questions slow you down. Ask your teacher directly.</p>
            </div>


            <div class="row g-4">


                <div class="col-lg-7">

                    <div class="form-card">

                        <form action="/student/doubts/post" method="POST">

                            <div class="mb-3">

                                <label class="form-label">Subject</label>

                                <select class="form-select" name="subject" required>

                                    <option value="" disabled selected>Select Subject</option>

                                    <option value="Mathematics">Mathematics</option>
                                    <option value="Science">Science</option>
                                    <option value="English">English</option>
                                    <option value="History">Social Science</option>
                                    <option value="Hindi">Hindi</option>
                                    <option value="Computer Science">Computer Science</option>

                                </select>

                            </div>


                            <div class="mb-3">

                                <label class="form-label">Your Question</label>

                                <textarea class="form-control" name="question" rows="5"
                                    placeholder="Type your doubt here in detail..." required></textarea>

                            </div>


                            <button type="submit" class="btn-submit">

                                <i class="fa-solid fa-paper-plane me-2"></i>

                                Submit Doubt

                            </button>

                        </form>

                    </div>

                </div>



                <div class="col-lg-5">

                    <h5 class="fw-bold mb-3">Recent Doubts</h5>

                    <% if(doubts.length===0){ %>

                        <div class="text-muted">
                            No doubts posted yet.
                        </div>

                        <% } %>


                            <% doubts.forEach(d=> { %>

                                <div
                                    class="history-item <%= d.status === 'Solved' ? 'status-resolved' : 'status-pending' %> shadow-sm">

                                    <div class="d-flex justify-content-between align-items-start">

                                        <span
                                            class="badge <%= d.status === 'Solved' ? 'bg-success' : 'bg-warning text-dark' %> mb-2">

                                            <%= d.status %>

                                        </span>

                                        <small class="text-muted">

                                            <%= new Date(d.created_at).toLocaleString() %>

                                        </small>

                                    </div>

                                    <h6 class="fw-bold mb-1">

                                        <%= d.subject %>

                                    </h6>

                                    <p class="small text-muted mb-2">

                                        <%= d.question %>

                                    </p>


                                    <% if(d.answer){ %>

                                        <div class="p-2 bg-white rounded border small">

                                            <strong>Teacher:</strong>

                                            <%= d.answer %>

                                        </div>

                                        <% } %>

                                </div>

                                <% }) %>

                </div>


            </div>

        </main>

    </div>

</body>

</html>