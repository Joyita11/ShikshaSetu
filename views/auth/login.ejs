<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
        rel="stylesheet">
</head>




<style>
    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        margin: 0;
    }

    .login-wrapper {
        /* This ensures it takes up the full screen height minus header */
        min-height: 100vh;
        background: radial-gradient(circle at top right, #06215ff3, #e0d5f1);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-card {
        border: none;
        border-radius: 50px !important;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        /* Modern frosted glass effect */
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05) !important;
    }

    .custom-input {
        background-color: #fcfcfd;
        border: 1.5px solid #edf2f7;
        padding: 14px;
        border-radius: 12px;
        transition: all 0.2s ease;
    }

    .custom-input:focus {
        background-color: #fff;
        border-color: #4e73df;
        box-shadow: 0 0 0 4px rgba(78, 115, 223, 0.1);
    }

    .btn-primary {
        background: #06215ff3;
        padding: 12px;
        border-radius: 12px;
        font-weight: 700;
    }

    .btn-primary:hover {
        background: #041a4cb1;
        box-sizing: border-box;
    }

    select:hover {
        background-color: rgba(0, 0, 0, 0.038);
    }

    input:hover {
        background-color: rgba(0, 0, 0, 0.038);
    }

    select option:hover {
        background-color: rgba(0, 0, 0, 0.038) !important;
    }
</style>



<section class="login-wrapper d-flex align-items-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">

                <div class="card login-card shadow-lg">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <h3 class="fw-bold">Welcome Back</h3>
                            <p class="text-muted small">Please enter your details to login</p>
                        </div>

                        <form action="/login" method="POST">
                            <div class="mb-3">
                                <label class="form-label small fw-bold">I am a:</label>
                                <select name="role" class="form-select custom-input" required>
                                    <option value="" disabled selected>Select your role</option>
                                    <option value="teacher">Teacher</option>
                                    <option value="student">Student</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold">Email Address</label>
                                <input type="email" name="email" class="form-control custom-input"
                                    placeholder="name@example.com" required>
                            </div>

                            <div class="mb-4">
                                <div class="d-flex justify-content-between">
                                    <label class="form-label small fw-bold">Password</label>

                                </div>
                                <input type="password" name="password" class="form-control custom-input"
                                    placeholder="••••••••" required>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold shadow-sm">
                                Sign In
                            </button>
                        </form>

                        <div class="text-center mt-4">
                            <p class="mb-0 small text-muted">
                                Don't have an account? <a href="/register" class="fw-bold text-decoration-none"
                                    style="color: #041a4cfc;">Sign
                                    Up</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>