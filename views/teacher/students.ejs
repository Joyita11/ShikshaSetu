<%- include('../partials/header', { title: 'Students Management' }) %>

    <head>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="/css/teachers/students.css">
    </head>

    <!-- ================= HEADER ================= -->
    <header class="dashboard-header">
        <button id="sidebarToggle"><i class="fa-solid fa-bars-staggered"></i></button>
        <h4 class="fw-bold mb-0" style="color: #00177e;">
            <i class="fa-solid fa-graduation-cap me-2" style="color: #00177e;"></i>ShikshaSetu
        </h4>

    </header>

    <!-- ================= SIDEBAR ================= -->
    <div class="sidebar" id="sidebar">
        <nav class="nav flex-column gap-2">
            <a href="/teacher/dashboard" class="nav-link">
                <i class="fa-solid fa-house"></i><span>Dashboard</span>
            </a>
            <a href="/teacher/doubts" class="nav-link">
                <i class="fa-solid fa-circle-question"></i><span>Solve Doubts</span>
            </a>
            <a href="/teacher/students" class="nav-link active">
                <i class="fa-solid fa-user-graduate"></i><span>Students</span>
            </a>
            <a href="/teacher/tasks" class="nav-link">
                <i class="fa-solid fa-list-check"></i><span>Assign Tasks</span>
            </a>
            <a href="/teacher/fees" class="nav-link">
                <i class="fa-solid fa-credit-card"></i><span>Due Fees</span>
            </a>
        </nav>

        <a href="/logout" class="nav-link text-danger fw-bold mt-auto">
            <i class="fa-solid fa-power-off"></i><span>Logout</span>
        </a>
    </div>

    <!-- ================= MAIN CONTENT ================= -->
    <main class="main-content pt-8">
        <div class="container-fluid">

            <!-- TITLE -->
            <div class="row mb-4 align-items-center">
                <div class="col-md-6">
                    <h2 class="fw-bold mb-1">Students Directory</h2>
                    <p class="text-muted mb-0">Manage all enrolled students</p>
                </div>
                <div class="col-md-6 text-end">
                    <button class="add-student-btn" data-bs-toggle="modal" data-bs-target="#addStudentModal">
                        <i class="fa-solid fa-plus me-2"></i> Add Student
                    </button>
                </div>
            </div>



            <!-- STUDENT TABLE -->
            <div class="card shadow-sm">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Class</th>
                                <th>Batch</th>
                                <th>School</th>
                                <th>Fees</th>
                                <th>Joined</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% if(students.length===0) { %>
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">
                                        No students found
                                    </td>
                                </tr>
                                <% } %>

                                    <% students.forEach(student=> { %>
                                        <tr data-id="<%= student.id %>" data-email="<%= student.email %>">


                                            <td class="student-name">
                                                <div class="d-flex align-items-center">
                                                    <img src="https://static.vecteezy.com/system/resources/thumbnails/032/176/191/small/business-avatar-profile-black-icon-man-of-user-symbol-in-trendy-flat-style-isolated-on-male-profile-people-diverse-face-for-social-network-or-web-vector.jpg?u=<%= student.id %>"
                                                        class="rounded-circle me-2" width="38">
                                                    <%= student.name %>
                                                </div>
                                            </td>
                                            <td class="student-class">
                                                <%= student.class %>
                                            </td>
                                            <td class="student-batch">
                                                <span class="badge bg-primary-subtle text-primary">
                                                    <%= student.batch %>
                                                </span>
                                            </td>
                                            <td class="student-school">
                                                <%= student.school %>
                                            </td>
                                            <td class="student-fees">₹<%= student.monthly_fees %>
                                            </td>
                                            <td class="student-joining-date"
                                                data-date="<%= student.joining_date.toISOString().slice(0,10) %>">
                                                <%= student.joining_date.toISOString().slice(0,10) %>
                                            </td>


                                            <td class="text-center">
                                                <!-- EDIT -->
                                                <button class="btn btn-sm btn-outline-primary btn-edit"
                                                    data-bs-toggle="modal" data-bs-target="#editStudentModal">
                                                    <i class="fa-solid fa-pen"></i>
                                                </button>

                                                <!-- DELETE -->
                                                <form action="/teacher/students/delete/<%= student.id %>" method="POST">
                                                    <button class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Delete this student?')">
                                                        <i class="fa-solid fa-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                        <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <!-- ================= ADD STUDENT MODAL ================= -->
    <div class="modal fade" id="addStudentModal">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <form action="/teacher/students/add" method="POST">
                    <div class="modal-header">
                        <h5 class="fw-bold">Add Student</h5>
                        <button class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body row g-3">
                        <div class="col-md-6">
                            <input name="name" class="form-control" placeholder="Full Name" required>
                        </div>

                        <div class="col-md-6">
                            <input name="email" type="email" class="form-control" placeholder="Student Email" required>
                        </div>

                        <div class="col-md-6">
                            <select name="class" class="form-select" required>
                                <option disabled selected>Select Class</option>
                                <% for(let i=1;i<=12;i++){ %>
                                    <option>Class <%= i %>
                                    </option>
                                    <% } %>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <select name="batch" class="form-select" required>
                                <option>1st Batch</option>
                                <option>2nd Batch</option>
                                <option>3rd Batch</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <input name="fees" type="number" class="form-control" placeholder="Monthly Fees" required>
                        </div>
                        <div class="col-12">
                            <input name="school" class="form-control" placeholder="School Name">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Joining Date</label>
                        <input type="date" name="joining_date" class="form-control" required>
                    </div>


                    <div class="modal-footer">
                        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ================= EDIT STUDENT MODAL ================= -->
    <div class="modal fade" id="editStudentModal">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <form id="editStudentForm" method="POST">
                    <div class="modal-header">
                        <h5 class="fw-bold">Edit Student</h5>
                        <button class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body row g-3">
                        <div class="col-md-6">
                            <input id="editName" name="name" class="form-control" required>
                        </div>

                        <div class="col-md-6">
                            <input id="editEmail" name="email" type="email" class="form-control" required>
                        </div>

                        <div class="col-md-6">
                            <select id="editClass" name="class" class="form-select">
                                <% for(let i=1;i<=12;i++){ %>
                                    <option>Class <%= i %>
                                    </option>
                                    <% } %>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <select id="editBatch" name="batch" class="form-select">
                                <option>1st Batch</option>
                                <option>2nd Batch</option>
                                <option>3rd Batch</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <input id="editFees" name="fees" type="number" class="form-control">
                        </div>
                        <div class="col-12">
                            <input id="editSchool" name="school" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Joining Date</label>
                            <input type="date" name="joining_date" id="editJoiningDate" class="form-control" required>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button class="btn btn-primary">Update</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ================= SCRIPTS ================= -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>






    <script>


        const toggleBtn = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');

        toggleBtn.addEventListener('click', () => {
            sidebar.classList.toggle('collapsed');
        });



        document.querySelectorAll('.btn-edit').forEach(btn => {
            btn.addEventListener('click', function () {
                const row = this.closest('tr');
                const id = row.dataset.id;

                document.getElementById('editName').value =
                    row.querySelector('.student-name').innerText.trim();

                document.getElementById('editEmail').value =
                    row.dataset.email;

                document.getElementById('editClass').value =
                    row.querySelector('.student-class').innerText.trim();
                document.getElementById('editBatch').value =
                    row.querySelector('.student-batch').innerText.trim();
                document.getElementById('editSchool').value =
                    row.querySelector('.student-school').innerText.trim();
                document.getElementById('editFees').value =
                    row.querySelector('.student-fees').innerText.replace('₹', '').trim();

                // ✅ NEW
                document.getElementById('editJoiningDate').value =
                    row.querySelector('.student-joining-date').dataset.date;

                document.getElementById('editStudentForm').action =
                    `/teacher/students/edit/${id}`;
            });
        });

    </script>