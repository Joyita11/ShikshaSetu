<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Assign Tasks & Homework</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
        rel="stylesheet">

    <link rel="stylesheet" href="/css/teachers/tasks.css">

</head>

<body>

    <header class="dashboard-header">

        <button id="sidebarToggle">
            <i class="fa-solid fa-bars-staggered"></i>
        </button>

        <h4 class="fw-bold text-primary mb-0">
            <i class="fa-solid fa-graduation-cap me-2"></i>ShikshaSetu
        </h4>




    </header>



    <div class="sidebar" id="sidebar">
        <nav class="nav flex-column gap-2">
            <a href="/teacher/dashboard" class="nav-link">
                <i class="fa-solid fa-house"></i><span>Dashboard</span>
            </a>
            <a href="/teacher/doubts" class="nav-link">
                <i class="fa-solid fa-circle-question"></i><span>Solve Doubts</span>
            </a>
            <a href="/teacher/students" class="nav-link">
                <i class="fa-solid fa-user-graduate"></i><span>Students</span>
            </a>
            <a href="/teacher/tasks" class="nav-link active">
                <i class="fa-solid fa-list-check"></i><span>Assign Tasks</span>
            </a>
            <a href="/teacher/fees" class="nav-link">
                <i class="fa-solid fa-credit-card"></i><span>Due Fees</span>
            </a>
        </nav>

        <a href="/logout" class="nav-link text-danger fw-bold mt-auto">
            <i class="fa-solid fa-power-off"></i><span>Logout</span>
        </a>
    </div>



    <main class="main-content pt-6">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <h3 class="fw-bold mb-0">
                Assign Tasks & Homework
            </h3>

            <div class="text-muted fw-semibold">
                Click a student to manage tasks
            </div>

        </div>



        <!-- STUDENTS FROM DATABASE -->

        <div class="row g-4">

            <% if (students && students.length) { %>

                <% students.forEach(s=> { %>

                    <div class="col-md-3">

                        <div class="student-task-card" data-bs-toggle="modal" data-bs-target="#taskModal"
                            onclick="prepareModal('<%= s.name %>', '<%= s.batch || 'Batch' %>', <%= s.id %>)">

                            <img src="https://ui-avatars.com/api/?name=<%= s.name %>&background=4361ee&color=fff"
                                class="avatar-lg shadow-sm" alt="avatar">

                            <h6 class="fw-bold mb-1">
                                <%= s.name %>
                            </h6>

                            <span class="badge rounded-pill bg-soft-primary text-primary" style="background:#eef2ff;">

                                <%= s.batch || '—' %>

                            </span>

                        </div>

                    </div>

                    <% }) %>

                        <% } else { %>

                            <div class="col-12 text-muted">
                                No students found. Add students first.
                            </div>

                            <% } %>

        </div>

    </main>



    <!-- TASK MODAL -->

    <div class="modal fade" id="taskModal" tabindex="-1">

        <div class="modal-dialog modal-dialog-centered modal-lg">

            <div class="modal-content p-4 shadow-lg">

                <div class="modal-header border-0 pb-0">

                    <div>

                        <h4 class="fw-bold mb-0" id="mStudentName">
                            Student Name
                        </h4>

                        <p class="text-muted mb-0" id="mStudentBatch">
                            Batch Info
                        </p>

                    </div>

                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>

                </div>



                <form action="/teacher/tasks/full-submit" method="POST" enctype="multipart/form-data"
                    onsubmit="return validateTasks()">

                    <div class="modal-body py-4">

                        <div class="row g-4">

                            <div class="col-md-6 border-end">

                                <input type="hidden" name="student_id" id="studentIdInput">

                                <input type="file" id="materialInput" name="material" accept="application/pdf,image/*"
                                    hidden>

                                <div class="upload-box" onclick="document.getElementById('materialInput').click()">

                                    <img src="/icons/pdf.png" width="40">

                                    <p class="mb-0">
                                        Click to upload PDF or Image
                                    </p>

                                </div>

                                <div id="previewBox" class="mt-3"></div>

                                <input type="text" name="title" class="form-control mt-3"
                                    placeholder="Title (e.g. Physics Notes)">

                            </div>



                            <div class="col-md-6">

                                <label class="fw-bold text-dark mb-3">

                                    <i class="fa-solid fa-list-check me-2 text-primary"></i>

                                    Homework To-Dos

                                </label>

                                <div id="todoList">

                                    <div class="todo-item d-flex align-items-center">

                                        <i class="fa-regular fa-circle me-2 text-muted"></i>

                                        <input type="text" name="tasks[]" class="todo-input"
                                            placeholder="Task 1 (e.g. Read Page 45)">

                                    </div>

                                </div>

                                <button type="button" class="btn btn-sm text-primary fw-bold p-0 mt-2"
                                    onclick="addNewTodo()">

                                    <i class="fa-solid fa-plus me-1"></i>

                                    Add Another Task

                                </button>

                            </div>

                        </div>

                    </div>



                    <div class="modal-footer border-0">

                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold w-100 py-3 shadow-sm">

                            <i class="fa-solid fa-paper-plane me-2"></i>

                            Send All Tasks

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        const toggleBtn = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');

        toggleBtn.addEventListener('click', () => {
            sidebar.classList.toggle('collapsed');
        });



        function prepareModal(name, batch, id) {

            document.getElementById('mStudentName').innerText = name;
            document.getElementById('mStudentBatch').innerText = batch;
            document.getElementById('studentIdInput').value = id;

            document.getElementById('previewBox').innerHTML = "";
            document.getElementById('materialInput').value = "";

            document.getElementById("todoList").innerHTML = `
<div class="todo-item d-flex align-items-center">
<i class="fa-regular fa-circle me-2 text-muted"></i>
<input type="text" name="tasks[]" class="todo-input" placeholder="Task 1">
</div>
`;

        }



        function addNewTodo() {

            const list = document.getElementById('todoList');

            const newItem = document.createElement('div');

            newItem.className = 'todo-item d-flex align-items-center mt-2';

            newItem.innerHTML = `
<i class="fa-regular fa-circle me-2 text-muted"></i>
<input type="text" name="tasks[]" class="todo-input" placeholder="Next task...">
`;

            list.appendChild(newItem);

        }



        function validateTasks() {

            const tasks = document.querySelectorAll("input[name='tasks[]']");

            for (let t of tasks) {

                if (t.value.trim() !== "") return true;

            }

            alert("Please add at least one task.");

            return false;

        }



        document.getElementById("materialInput").addEventListener("change", function () {

            const previewBox = document.getElementById("previewBox");

            previewBox.innerHTML = "";

            if (this.files.length > 0) {

                const file = this.files[0];

                const fileType = file.type;

                if (fileType.startsWith("image/")) {

                    const img = document.createElement("img");

                    img.src = URL.createObjectURL(file);

                    img.className = "img-fluid rounded shadow-sm mt-2";

                    img.style.maxWidth = "220px";

                    previewBox.appendChild(img);

                }

                else if (fileType === "application/pdf") {

                    const link = document.createElement("a");

                    link.href = URL.createObjectURL(file);

                    link.target = "_blank";

                    link.className = "d-inline-flex align-items-center mt-2 text-decoration-none";

                    link.innerHTML = `<img src="/icons/pdf.png" width="32" class="me-2"><span>${file.name}</span>`;

                    previewBox.appendChild(link);

                }

                else {

                    previewBox.textContent = "Unsupported file type.";

                }

            }

        });

    </script>

</body>

</html>