<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/teachers/fees.css">
</head>

<header class="dashboard-header">
    <button id="sidebarToggle"><i class="fa-solid fa-bars-staggered"></i></button>
    <h4 class="fw-bold text-primary mb-0">
        <i class="fa-solid fa-graduation-cap me-2"></i>ShikshaSetu
    </h4>

    <!-- <div class="ms-auto">
            <a href="/profile" class="profile-nav-link">
                <div class="profile-ring">
                    <img src="https://ui-avatars.com/api/?name=John+Doe&background=4361ee&color=fff" alt="Profile"
                        class="header-profile-img">
                </div>
            </a>
        </div> -->
</header>

<div class="sidebar" id="sidebar">
    <nav class="nav flex-column gap-2">
        <a href="/teacher/dashboard" class="nav-link">
            <i class="fa-solid fa-house"></i><span>Dashboard</span>
        </a>
        <a href="/teacher/doubts" class="nav-link">
            <i class="fa-solid fa-circle-question"></i><span>Solve Doubts</span>
        </a>
        <a href="/teacher/students" class="nav-link">
            <i class="fa-solid fa-user-graduate"></i><span>Students</span>
        </a>
        <a href="/teacher/tasks" class="nav-link">
            <i class="fa-solid fa-list-check"></i><span>Assign Tasks</span>
        </a>
        <a href="/teacher/fees" class="nav-link active">
            <i class="fa-solid fa-credit-card"></i><span>Due Fees</span>
        </a>
    </nav>

    <a href="/logout" class="nav-link text-danger fw-bold mt-auto">
        <i class="fa-solid fa-power-off"></i><span>Logout</span>
    </a>
</div>



<main class="main-content pt-8">
    <div class="container-fluid">
        <h2 class="fw-bold mb-4">Fees Management</h2>

        <div class="fees-card">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Class</th>
                        <th>Batch</th>
                        <th>Pending Months</th>
                        <th>Total Due</th>
                    </tr>
                </thead>
                <tbody>

                    <% students.forEach(s=> { %>
                        <tr>
                            <td class="fw-bold">
                                <%= s.name %>
                            </td>
                            <td>
                                <%= s.class %>
                            </td>
                            <td>
                                <%= s.batch %>
                            </td>

                            <td>
                                <% const
                                    months=["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]; %>

                                    <% months.forEach(m=> { %>
                                        <form action="/teacher/fees/toggle-month" method="POST" class="d-inline">
                                            <input type="hidden" name="student_id" value="<%= s.id %>">
                                            <input type="hidden" name="month" value="<%= m %>">
                                            <input type="hidden" name="year" value="2026">

                                            <button
                                                class="btn btn-sm <%= s.pending_months.includes(m) ? 'btn-danger' : 'btn-outline-success' %>">
                                                <%= m %>
                                            </button>
                                        </form>
                                        <% }) %>
                            </td>



                            <td class="amount-bold">₹<%= s.total_due %>
                            </td>


                        </tr>
                        <% }) %>

                </tbody>
            </table>
        </div>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const toggleBtn = document.getElementById('sidebarToggle');
    const sidebar = document.getElementById('sidebar');

    toggleBtn.addEventListener('click', () => {
        sidebar.classList.toggle('collapsed');
    });
</script>

<%- include('../partials/footer') %>