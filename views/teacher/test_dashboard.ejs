<div class="main-wrapper">
    <div class="sidebar" id="sidebar">
        <nav class="nav flex-column mt-2">
            <a href="/teacher/dashboard" class="nav-link active">
                <i class="fa-solid fa-house"></i> <span>Dashboard</span>
            </a>
            <a href="/teacher/doubts" class="nav-link">
                <i class="fa-solid fa-circle-question"></i> <span>Solve Doubts</span>
            </a>
            <a href="/teacher/students" class="nav-link">
                <i class="fa-solid fa-user-group"></i> <span>Students</span>
            </a>
            <a href="/teacher/tasks" class="nav-link">
                <i class="fa-solid fa-list-check"></i> <span>Assign Tasks</span>
            </a>
            <a href="/teacher/fees" class="nav-link">
                <i class="fa-solid fa-credit-card"></i> <span>Due Fees</span>
            </a>

            <div class="mt-auto pt-4">
                <a href="/logout" class="nav-link text-danger fw-bold">
                    <i class="fa-solid fa-power-off"></i> <span>Logout</span>
                </a>
            </div>
        </nav>
    </div>

    <main class="main-content">
        <div class="container-fluid">
            <div class="welcome-card mb-4 shadow-sm">
                <div class="row align-items-center">
                    <div class="col-lg-8">
                        <h1 class="fw-bold mb-3">Hello, Teacher! 👋</h1>
                        <p class="opacity-75 mb-4 fs-5">Get ready to manage your tuition tasks efficiently.</p>
                        <a href="/profile" class="btn btn-light rounded-pill px-4 py-2 text-primary fw-bold">Go to
                            profile</a>
                    </div>
                    <div class="col-lg-4 d-none d-lg-block text-center">
                        <img src="https://illustrations.popsy.co/white/working-at-home.svg" alt="Illustration"
                            style="height: 180px;">
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-sm-6 col-xl-3">
                    <div class="stat-card shadow-sm border-0 p-4 bg-white h-100">
                        <div class="icon-box bg-primary-subtle mb-3 text-primary">
                            <i class="fa-solid fa-user-graduate"></i>
                        </div>
                        <p class="text-muted mb-1 fw-semibold">Total Students</p>
                        <h2 class="fw-bold mb-0">
                            <%= totalStudents %>
                        </h2>
                    </div>
                </div>

                <div class="col-sm-6 col-xl-3">
                    <div class="stat-card shadow-sm border-0 p-4 bg-white h-100">
                        <div class="icon-box bg-success-subtle mb-3 text-success">
                            <i class="fa-solid fa-layer-group"></i>
                        </div>
                        <p class="text-muted mb-1 fw-semibold">Active Batches</p>
                        <h2 class="fw-bold mb-0">
                            <%= activeBatches %>
                        </h2>
                    </div>
                </div>

                <div class="col-sm-6 col-xl-3">
                    <div class="stat-card shadow-sm border-0 p-4 bg-white h-100">
                        <div class="icon-box bg-danger-subtle mb-3 text-danger">
                            <i class="fa-solid fa-indian-rupee-sign"></i>
                        </div>
                        <p class="text-muted mb-1 fw-semibold">Pending Fees</p>
                        <h2 class="fw-bold mb-0 text-danger">
                            <%= pendingFees %> <span class="fs-6 text-muted fw-normal">Students</span>
                        </h2>
                    </div>
                </div>

                <div class="col-sm-6 col-xl-3">
                    <div class="stat-card shadow-sm border-0 p-4 bg-white h-100">
                        <div class="icon-box bg-warning-subtle mb-3 text-warning">
                            <i class="fa-solid fa-list-check"></i>
                        </div>
                        <p class="text-muted mb-1 fw-semibold">Doubts</p>
                        <h2 class="fw-bold mb-0">08</h2>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

