<% const avatarName=teacher && teacher.name ? encodeURIComponent(teacher.name) : "Teacher" ; %>


    <head>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="/css/teachers/profile.css">
    </head>

    <header class="dashboard-header">
        <button id="sidebarToggle"><i class="fa-solid fa-bars-staggered"></i></button>
        <h4 class="fw-bold text-primary mb-0">
            <i class="fa-solid fa-graduation-cap me-2"></i>TuitionPro
        </h4>

        <div class="ms-auto">
            <a href="/profile" class="profile-nav-link">
                <div class="profile-ring">
                    <img src="<%= teacher.profile_photo ? teacher.profile_photo : `https://ui-avatars.com/api/?name=${encodeURIComponent(teacher.name || 'Teacher')}&background=06215f&color=fff` %>"
                        class="header-profile-img" />
                    <!-- <img src="https://ui-avatars.com/api/?name=John+Doe&background=4361ee&color=fff" alt="Profile" class="header-profile-img"> -->

                </div>
            </a>
        </div>
    </header>

    <div class="sidebar" id="sidebar">
        <nav class="nav flex-column gap-2">
            <a href="/teacher/dashboard" class="nav-link active">
                <i class="fa-solid fa-house"></i>
                <span>Dashboard</span>
            </a>
            <a href="/teacher/doubts" class="nav-link">
                <i class="fa-solid fa-user-group"></i>
                <span>Solve Doubts</span>
            </a>

            <a href="/teacher/students" class="nav-link">
                <i class="fa-solid fa-user-group"></i>
                <span>Students</span>
            </a>
            <a href="/teacher/tasks" class="nav-link">
                <i class="fa-solid fa-user-group"></i>
                <span>Assign Tasks</span>
            </a>
            <a href="/teacher/fees" class="nav-link">
                <i class="fa-solid fa-credit-card"></i>
                <span>Due Fees</span>
            </a>
        </nav>
        <a href="/logout" class="nav-link text-danger fw-bold">
            <i class="fa-solid fa-power-off"></i>
            <span>Logout</span>
        </a>
    </div>

    <main class="main-content">
        <div class="container-fluid">
            <div class="profile-cover"></div>
            <form method="POST" action="/profile/update" class="profile-card p-4 mt-0">
                <div class="profile-card text-center mb-4" id="identitySection">
                    <div class="profile-img-container">
                        <img src="<%= teacher.profile_photo ? teacher.profile_photo : `https://ui-avatars.com/api/?name=${encodeURIComponent(teacher.name || 'Teacher')}&background=06215f&color=fff` %>"
                            class="profile-img" id="profileDisplay" />
                        <div class="photo-edit-overlay" onclick="document.getElementById('photoInput').click()">
                            <i class="fa-solid fa-camera"></i>
                        </div>
                        <form action="/profile/photo" method="POST" enctype="multipart/form-data">
                            <input type="file" name="photo" id="photoInput" hidden accept="image/*"
                                onchange="this.form.submit()">
                        </form>
                    </div>
                    <div class="mt-3">
                        <div class="text-center mb-3">
                            <span class="info-value name-text">
                                <%= teacher.name || "Your Name" %>
                            </span>

                            <input type="text" name="name" class="editable-input name-input text-center"
                                value="<%= teacher.name || '' %>" style="display:none;">
                        </div>




                        <p class="text-muted mb-3">Senior Mathematics Tutor</p>
                        <div class="d-flex justify-content-center gap-2 mb-4">
                            <span class="badge-subject">Advanced Calculus</span>
                            <span class="badge-subject">Physics</span>
                            <span class="badge-subject">Algebra</span>
                        </div>
                        <button class="edit-profile-btn" id="editIdentityBtn"><i
                                class="fa-solid fa-pen-to-square me-2"></i>Edit
                            Profile</button>

                        <div id="identityActions" style="display:none;" class="mt-2">
                            <button class="btn btn-sm btn-primary px-4" onclick="saveIdentity()">Save</button>
                            <button class="btn btn-sm btn-light px-4" onclick="toggleIdentity(false)">Cancel</button>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-lg-4">
                        <div class="profile-card p-4 mt-0">
                            <h5 class="fw-bold mb-4 text-start">Performance</h5>
                            <div class="row g-3">
                                <div class="col-6">
                                    <div class="stat-box">
                                        <h4>
                                            <%= stats.students %>
                                        </h4>
                                        <h4>
                                            <%= stats.batches %>
                                        </h4>
                                        <h4>
                                            <%= stats.tasks %>
                                        </h4><small class="text-muted">Students</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="stat-box">
                                        <h4 class="fw-bold text-success mb-0">12</h4><small
                                            class="text-muted">Batches</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="stat-box">
                                        <h4 class="fw-bold text-warning mb-0">4.9</h4><small
                                            class="text-muted">Rating</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="stat-box">
                                        <h4 class="fw-bold text-info mb-0">95%</h4><small
                                            class="text-muted">Attendance</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-8">


                        <h5 class="fw-bold mb-4 text-start">Account Details</h5>
                        <div class="row text-start">
                            <div class="col-md-6" id="field-email">
                                <p class="info-label">Email Address <i class="fa-solid fa-pen edit-pen-icon"
                                        onclick="editField('field-email')"></i></p>
                                <span class="info-value">
                                    <%= teacher.email || "Not set" %>
                                </span>

                                <input type="email" name="email" class="editable-input"
                                    value="<%= teacher.email || '' %>" style="display:none;">

                            </div>
                            <div class="col-md-6" id="field-phone">
                                <p class="info-label">Phone Number <i class="fa-solid fa-pen edit-pen-icon"
                                        onclick="editField('field-phone')"></i></p>
                                <span class="info-value">
                                    <%= teacher.phone || "Not set" %>
                                </span>
                                <input type="text" name="phone" class="editable-input"
                                    value="<%= teacher.phone || '' %>" style="display:none;">

                            </div>
                            <div class="col-md-6" id="field-qual">
                                <p class="info-label">Qualifications <i class="fa-solid fa-pen edit-pen-icon"
                                        onclick="editField('field-qual')"></i></p>
                                <span class="info-value">
                                    <%= teacher.qualification || "Not set" %>
                                </span>

                                <input type="text" name="qualification" class="editable-input"
                                    value="<%= teacher.qualification || '' %>" style="display:none;">

                            </div>
                            <div class="col-md-6" id="field-exp">
                                <p class="info-label">Experience <i class="fa-solid fa-pen edit-pen-icon"
                                        onclick="editField('field-exp')"></i></p>
                                <span class="info-value">
                                    <%= teacher.experience || "Not set" %>
                                </span>
                                <input type="text" name="experience" class="editable-input"
                                    value="<%= teacher.experience || '' %>" style="display:none;">

                            </div>
                            <div class="col-12 mt-3" id="field-bio">
                                <p class="info-label">Bio / Methodology <i class="fa-solid fa-pen edit-pen-icon"
                                        onclick="editField('field-bio')"></i></p>
                                <span class="info-value fw-normal" style="font-size: 14px; line-height: 1.6;">
                                    <%= teacher.bio || "Not set" %>
                                </span>
                                <textarea name="bio" class="editable-input" rows="3"
                                    style="display:none;"><%= teacher.bio || '' %></textarea>

                            </div>
                        </div>
                        <div class="text-end mt-3">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fa-solid fa-floppy-disk me-2"></i>Save Changes
                            </button>
                        </div>
            </form>


        </div>
        </div>
        </div>
    </main>

    <script>
        // Sidebar Toggle (Your original script)
        const toggleBtn = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        toggleBtn.addEventListener('click', () => { sidebar.classList.toggle('collapsed'); });

        // 1. Identity Edit Logic
        const identitySection = document.getElementById('identitySection');
        const editIdentityBtn = document.getElementById('editIdentityBtn');
        const identityActions = document.getElementById('identityActions');

        function toggleIdentity(isEditing) {
            if (isEditing) {
                identitySection.classList.add('header-editing');
                editIdentityBtn.style.display = 'none';
                identityActions.style.display = 'block';
            } else {
                identitySection.classList.remove('header-editing');
                editIdentityBtn.style.display = 'inline-block';
                identityActions.style.display = 'none';
            }
        }

        editIdentityBtn.addEventListener('click', () => toggleIdentity(true));
        function saveIdentity() {
            document.querySelector('form[action="/profile/update"]').submit();
        }



        // 2. Field Pen Edit Logic
        function editField(id) {
            const field = document.getElementById(id);

            const span = field.querySelector('.info-value');
            const input = field.querySelector('.editable-input');

            span.style.display = 'none';
            input.style.display = 'block';

            input.focus();
        }


        // Photo Preview
        document.getElementById('photoInput').addEventListener('change', function (e) {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = (e) => document.getElementById('profileDisplay').src = e.target.result;
                reader.readAsDataURL(this.files[0]);
            }
        });
    </script>

    <%- include('../partials/footer') %>