<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/teachers/dashboard.css">
</head>

<header class="dashboard-header">
    <button id="sidebarToggle"><i class="fa-solid fa-bars-staggered"></i></button>
    <h4 class="fw-bold text-primary mb-0">
        <i class="fa-solid fa-graduation-cap me-2"></i>ShikshaSetu
    </h4>


</header>

<div class="main-wrapper">
    <div class="sidebar" id="sidebar">
        <nav class="nav flex-column gap-2">
            <a href="/teacher/dashboard" class="nav-link active">
                <i class="fa-solid fa-house"></i><span>Dashboard</span>
            </a>
            <a href="/teacher/doubts" class="nav-link">
                <i class="fa-solid fa-circle-question"></i><span>Solve Doubts</span>
            </a>
            <a href="/teacher/students" class="nav-link">
                <i class="fa-solid fa-user-graduate"></i><span>Students</span>
            </a>
            <a href="/teacher/tasks" class="nav-link">
                <i class="fa-solid fa-list-check"></i><span>Assign Tasks</span>
            </a>
            <a href="/teacher/fees" class="nav-link">
                <i class="fa-solid fa-credit-card"></i><span>Due Fees</span>
            </a>
        </nav>

        <a href="/logout" class="nav-link text-danger fw-bold mt-auto">
            <i class="fa-solid fa-power-off"></i><span>Logout</span>
        </a>
    </div>

    <main class="main-content pt-8">
        <div class="container-fluid">
            <div class="welcome-banner mb-4 shadow-sm">
                <div class="row align-items-center">
                    <div class="col-lg-8">
                        <h1 class="fw-bold mb-3">Hello, Teacher! 👋</h1>
                        <p class="opacity-75 mb-4 fs-5">Get ready to manage your tuition tasks efficiently.</p>

                    </div>
                    <div class="col-lg-4 d-none d-lg-block text-center">
                        <img src="https://cdni.iconscout.com/illustration/premium/thumb/man-working-on-laptop-at-home-4488756-3738450.png"
                            alt="Teacher working"
                            style="height: 220px; position: absolute; right: 30px; top: 50%; transform: translateY(-50%); z-index: 1;">
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-sm-6 col-xl-3">
                    <div class="stat-card shadow-sm border-0 h-100">
                        <div class="icon-box bg-primary-subtle text-primary">
                            <i class="fa-solid fa-user-graduate"></i>
                        </div>
                        <p class="text-muted mb-1 fw-semibold">Total Students</p>
                        <h2 class="fw-bold mb-0">
                            <%= totalStudents %>
                        </h2>
                    </div>
                </div>

                <div class="col-sm-6 col-xl-3">
                    <div class="stat-card shadow-sm border-0 h-100">
                        <div class="icon-box bg-success-subtle text-success">
                            <i class="fa-solid fa-layer-group"></i>
                        </div>
                        <p class="text-muted mb-1 fw-semibold">Active Batches</p>
                        <h2 class="fw-bold mb-0">
                            <%= activeBatches %>
                        </h2>
                    </div>
                </div>

                <div class="col-sm-6 col-xl-3">
                    <div class="stat-card shadow-sm border-0 h-100">
                        <div class="icon-box bg-danger-subtle text-danger">
                            <i class="fa-solid fa-indian-rupee-sign"></i>
                        </div>
                        <p class="text-muted mb-1 fw-semibold">Pending Fees</p>
                        <h2 class="fw-bold mb-0 text-danger">
                            <%= pendingFees %> <span class="fs-6 text-muted fw-normal">Students</span>
                        </h2>
                    </div>
                </div>

                <div class="col-sm-6 col-xl-3">
                    <div class="stat-card shadow-sm border-0 h-100">
                        <div class="icon-box bg-warning-subtle text-warning">
                            <i class="fa-solid fa-list-check"></i>
                        </div>
                        <p class="text-muted mb-1 fw-semibold">Doubts</p>
                        <h2 class="fw-bold mb-0">
                            <%= totalDoubts %>
                        </h2>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const toggleBtn = document.getElementById('sidebarToggle');
    const sidebar = document.getElementById('sidebar');

    toggleBtn.addEventListener('click', () => {
        sidebar.classList.toggle('collapsed');
    });
</script>