<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShikshaSetu | Professional Education Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --bg-dark: #0f172a;
            /* Deep Navy/Black */
            --accent-purple: #8b5cf6;
            /* Royal Purple */
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --btn-glow: rgba(139, 92, 246, 0.3);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            margin: 0;
            line-height: 1.6;
        }

        /* Sophisticated Radial Glow Background */
        .hero-section {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            overflow: hidden;
            background: radial-gradient(circle at 0% 0%, rgba(139, 92, 246, 0.15) 0%, transparent 40%),
                radial-gradient(circle at 100% 100%, rgba(139, 92, 246, 0.1) 0%, transparent 40%);
        }

        /* Typography */
        h1 {
            font-weight: 800;
            font-size: 4rem;
            letter-spacing: -0.03em;
            margin-bottom: 1.5rem;
            background: linear-gradient(180deg, #FFFFFF 0%, #cbd5e1 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .lead {
            font-size: 1.25rem;
            color: var(--text-muted);
            max-width: 90%;
            margin-bottom: 2.5rem;
        }

        /* Professional Image Treatment */
        .img-wrapper {
            position: relative;
            padding: 20px;
        }

        .img-wrapper::after {
            content: "";
            position: absolute;
            inset: 0;
            border: 1px solid rgb(146, 188, 230);
            border-radius: 30px;
            z-index: -1;
            transform: rotate(-3deg);
        }

        .hero-img {
            border-radius: 24px;
            box-shadow: 0 50px 100px -20px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
            image-rendering: optimizeQuality;
        }

        /* High-End Button */
        .btn-primary-pro {
            background-color: var(--accent-purple);
            color: white;
            font-weight: 600;
            padding: 14px 32px;
            border-radius: 12px;
            border: none;
            transition: all 0.2s ease-in-out;
            box-shadow: 0 4px 15px var(--btn-glow);
            text-decoration: none;
            display: inline-block;
        }

        .btn-primary-pro:hover {
            background-color: #a78bfa;
            transform: translateY(-2px);
            box-shadow: 0 8px 25px var(--btn-glow);
            color: white;
        }

        /* Subtle Accent for Features */
        .badge-purple {
            background: rgba(139, 92, 246, 0.1);
            color: var(--accent-purple);
            padding: 8px 16px;
            border-radius: 100px;
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 1rem;
            display: inline-block;
            border: 1px solid rgba(139, 92, 246, 0.2);
        }

        @media (max-width: 991px) {
            h1 {
                font-size: 2.8rem;
            }

            .hero-section {
                padding-top: 80px;
                text-align: center;
            }

            .justify-content-md-start {
                justify-content: center !important;
            }
        }
    </style>
</head>

<body>

    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6 order-2 order-lg-1">
                    <span class="badge-purple">Education Reinvented</span>
                    <h1 class="display-4">ShikshaSetu</h1>
                    <p class="lead">
                        The definitive bridge for modern education. A secure, high-performance platform
                        designed for educators to manage administrative tasks while empowering
                        students to achieve academic excellence.
                    </p>
                    <form class="d-flex gap-3 d-md-flex justify-content-md-start" action="/register" method="get">
                        <button type="submit" class="btn-primary-pro">Get Started Free</button>
                    </form>
                </div>

                <div class="col-lg-6 order-1 order-lg-2">
                    <div class="img-wrapper">
                        <img src="/images/teacher.png" class="d-block mx-lg-auto img-fluid hero-img"
                            alt="Professional Platform" width="600" height="450" loading="lazy">
                    </div>
                </div>
            </div>
        </div>
    </section>

</body>

</html>